# OneSignal push notifications (Settings > Keys & IDs en onesignal.com)
# Crea una app en https://onesignal.com y completa estos valores
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# SMTP para emails de recuperacion de contrasena (ej: Gmail con app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# URL publica de la app (para links de reset de contrasena)
APP_URL=http://localhost:3000

# Secreto para sesiones express (cambiar en produccion)
SESSION_SECRET=household-tasks-dev-secret

# Directorio donde se guarda data.json (por defecto: mismo directorio que db/)
DATA_DIR=
